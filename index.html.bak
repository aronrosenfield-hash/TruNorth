<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- 2026-06-05 (PageSpeed Tier 1 / a11y): removed maximum-scale=1.0 and
         user-scalable=no. They block pinch-zoom which is an a11y violation
         (Lighthouse a11y: -5 to -10 pts). Apple iOS WKWebView already prevents
         pinch-zoom inside Capacitor apps natively, and the input-focus auto-
         zoom we used to suppress is now handled by fontSize:16 on inputs
         (see App.jsx selects + the H4 fix comment). Web visitors regain the
         ability to pinch-zoom on the marketing landing — net a11y win. -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- PWA / Home Screen -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="TruNorth" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#1a1a1a" />
    <link rel="manifest" href="/manifest.json" />

    <!-- SEO / Share — 2026-06-01: sharpened for launch. Lead with the
         differentiator ("public records, not opinions") since every cold
         share-preview decision happens in the first ~10 words. -->
    <meta name="description" content="11,000+ companies tracked across 9 value categories using only public records — FEC, OSHA, EPA, SEC, NLRB. No opinions. No vibes. Free on iOS." />
    <link rel="canonical" href="https://www.trunorthapp.com/" />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TruNorth" />
    <meta property="og:title" content="TruNorth — Shop with your values. Real data, not opinions." />
    <meta property="og:description" content="11,000+ companies tracked across politics, environment, labor, animal welfare, privacy & more — using only public records. Free on iOS." />
    <meta property="og:url" content="https://www.trunorthapp.com/" />
    <meta property="og:image" content="https://www.trunorthapp.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TruNorth — 11,000+ brands tracked using public records" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="TruNorth — Shop with your values. Real data, not opinions." />
    <meta name="twitter:description" content="11,000+ brands tracked using public records — FEC, OSHA, EPA, SEC. No vibes. Free on iOS." />
    <meta name="twitter:image" content="https://www.trunorthapp.com/og-image.png" />

    <!-- Apple touch icon -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ── Entity definition (GEO) ──────────────────────────────────────────
         A single, canonical "what is TruNorth" record so answer engines
         (ChatGPT, Claude, Perplexity, Gemini, AI Overviews) resolve the right
         entity and don't conflate us with TruNorth Federal Credit Union,
         TruNorth Global (warranties), etc. Keep this description in sync with
         /llms.txt and the App Store / Product Hunt / social bios. -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.trunorthapp.com/#org",
          "name": "TruNorth",
          "alternateName": "TruNorth app",
          "url": "https://www.trunorthapp.com/",
          "logo": "https://www.trunorthapp.com/apple-touch-icon.png",
          "description": "TruNorth is a free iOS app that grades 11,000+ consumer brands across nine values categories — political donations, environment, labor, DEI, charitable giving, animal welfare, firearms, data privacy, and executive pay — using only public records from 175+ sources including the FEC, EPA, OSHA, SEC, NLRB, CFPB, and federal courts. A 30-second values quiz personalizes every grade.",
          "disambiguatingDescription": "Consumer-values brand-rating app. Not affiliated with TruNorth Federal Credit Union, TruNorth Global, TruNorth Advisors, or any other entity sharing the name.",
          "foundingDate": "2026",
          "founder": { "@type": "Person", "name": "Aron Rosenfield" },
          "sameAs": [
            "https://x.com/TruNorthapp"
          ]
        },
        {
          "@type": "MobileApplication",
          "@id": "https://www.trunorthapp.com/#app",
          "name": "TruNorth",
          "applicationCategory": "LifestyleApplication",
          "operatingSystem": "iOS",
          "url": "https://www.trunorthapp.com/",
          "publisher": { "@id": "https://www.trunorthapp.com/#org" },
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
          "description": "Grade 11,000+ consumer brands on the values you care about, from public records. Scan or search a brand, take a 30-second quiz, and get a personalized letter grade with every source shown."
        },
        {
          "@type": "WebSite",
          "@id": "https://www.trunorthapp.com/#website",
          "url": "https://www.trunorthapp.com/",
          "name": "TruNorth",
          "publisher": { "@id": "https://www.trunorthapp.com/#org" }
        }
      ]
    }
    </script>

    <title>TruNorth — Know where your money goes</title>
    <!-- Tabler icons served locally via npm (bundled by Vite, no CDN dependency) -->

    <!-- ── Critical layout CSS ──────────────────────────────────────────────
         Lives here (not in React) so it is applied on the very first paint,
         before the JS bundle even loads.  React injects the same rules again
         later — last-write wins for same-specificity, values are identical.
         html height: var(--app-height, 100dvh) is set by the inline script
         below using screen.height in standalone mode (keyboard-immune) and
         innerHeight in browser mode. ──────────────────────────────────────── -->
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
      /* 2026-06-01 STRONGER FIX for "entire screen moves" on Capacitor WKWebView:
         Previous overscroll-behavior + position:fixed wasn't enough because
         Capacitor's WKWebView has its OWN UIScrollView wrapping the whole web
         content, and that's what was bouncing. Disabled at the Capacitor
         level (scrollEnabled:false + contentInset:never in capacitor.config.json).
         CSS reinforcement here so web builds also stay still. */
      html, body {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        width: 100%; height: 100%; max-width: 100%;
        overflow: hidden;
        overscroll-behavior: none;
        -webkit-overflow-scrolling: auto;  /* disable momentum on body */
        touch-action: none;                /* body itself doesn't react to drag */
        background: #1a1a1a;
      }
      #root { background: #1a1a1a; width: 100%; height: 100%; max-width: 100%; overflow: hidden; touch-action: pan-y; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 15px; color: #f2f2f2; }
      input, textarea, select, button { font-family: inherit; }
      input:focus, textarea:focus, select:focus { outline: none; }
      @keyframes spin { to { transform: rotate(360deg); } }
      .spin { animation: spin 0.7s linear infinite; display: inline-block; }
      ::placeholder { color: #555; }
    </style>

    <!-- Set --app-height BEFORE first paint.
         Standalone PWA: window.screen.height = full physical screen in CSS px,
         NEVER changes when the keyboard opens/closes (unlike window.innerHeight).
         This is what prevents the black bar that reappears after typing in a field.
         Browser: use innerHeight so the layout follows the browser viewport. -->
    <script>
      (function () {
        var h = window.navigator.standalone === true
          ? (window.screen.height || window.innerHeight)
          : window.innerHeight;
        document.documentElement.style.setProperty('--app-height', h + 'px');
      })();
    </script>
  </head>
  <body style="background:#1a1a1a;margin:0;">
    <div id="root"></div>
    <script type="module" src="/src/main.jsx"></script>
  </body>
</html>
