# Android release signing — TEMPLATE ONLY.
#
#   cp android/keystore.properties.example android/keystore.properties
#
# `android/keystore.properties` is gitignored, as are *.jks / *.keystore.
# NEVER commit the real file or the keystore itself.
#
# app/build.gradle reads these, falling back to the env vars in brackets so CI
# can sign without a properties file. If neither resolves, the release build
# still succeeds — it just produces an UNSIGNED apk/aab.

# Absolute path to the keystore, or a path relative to android/
# [env: ANDROID_KEYSTORE_FILE]
storeFile=/Users/aronrosenfield/Developer/keys/trunorth-release.keystore

# [env: ANDROID_KEYSTORE_PASSWORD]
storePassword=

# The -alias you passed to keytool  [env: ANDROID_KEY_ALIAS]
keyAlias=trunorth

# [env: ANDROID_KEY_PASSWORD]  — same as storePassword unless you set a separate one
keyPassword=
