.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Env files: ignore all variants by default, allow only example templates
.env
.env.*
!.env.*.example
!.env.testflight.example
build/
*.xcarchive
scripts/ExportOptions.plist

# Claude Code session data
.claude/

# Phase 5.am: iOS / Capacitor — commit the project source, ignore build artifacts
ios/App/Pods/
ios/App/build/
ios/App/.build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/
*.xcuserstate
*.xcuserdatad
ios/App/Podfile.lock
# Web build mirror inside iOS — regenerated by `npx cap sync ios`, no need to commit
ios/App/App/public/

# v1.2 (2026-07-20): Android / Capacitor — same rule as iOS above. Commit the
# project source, ignore every build artifact and the synced web mirror.
# assets/public alone is ~130MB (dist + public/data) and is fully regenerated
# by `npx cap sync android`, so it must never enter git.
android/app/src/main/assets/public/
android/app/build/
android/build/
android/.gradle/
android/captures/
android/.idea/
android/app/release/
android/app/debug/
android/local.properties
*.apk
*.aab
# Release signing material — NEVER commit. Losing the keystore means you can
# never update the Play listing again; back it up to encrypted storage instead.
android/keystore.properties
*.jks
*.keystore

# Wikidata SPARQL cache (regenerated by scripts/build-brand-parent-map.mjs)
scripts/cache/

# Local fetch caches (regeneratable)
.cache/

# IRS bulk files — 400MB, re-downloaded by the fetcher; never commit
public/data/_cache/irs990pf/
# R7: 52MB OFCCP XLSX stays out of git; the derived JSON + dictionary are committed
data/raw/ofccp-eeo1/*.xlsx

# C2 (2026-06-11 tech review): pipeline fetch caches are NOT product data —
# they were 398MB tracked in git, deployed to Vercel, and bundled into the
# 521MB iOS .ipa. Fetchers re-download on cache miss (annual/quarterly).
public/data/_cache/

# stale dev artifacts (2026-07-04 cleanup)
*.bak
dev.log
