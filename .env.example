# TruNorth — environment variables
#
# Copy to `.env` and fill in. `.env` is gitignored; NEVER commit real values.
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  VITE_* VARS ARE COMPILED INTO THE CLIENT BUNDLE.
# Anything with a VITE_ prefix ships inside the web app AND inside the iOS/
# Android binaries, and is readable by anyone who inspects them. Only ever put
# PUBLIC/publishable keys here. A secret key in a VITE_ var is a leak.
# ─────────────────────────────────────────────────────────────────────────────


# ── Payments — RevenueCat ────────────────────────────────────────────────────
# These are the PUBLIC SDK keys from RevenueCat → API keys → "SDK API keys".
# Do NOT use anything from the "Secret API keys" section — RevenueCat's own
# warning is that those must never touch front-end code, and VITE_ vars ARE
# front-end code.
#
# Keys are PER PLATFORM and not interchangeable (B-75): payments.js selects one
# via Capacitor.getPlatform(). An iOS key on Android means the paywall renders
# and every purchase fails.
#
# ⚠️ The native apps are built from `dist/`, which `npm run build` generates on
# YOUR machine — so these must be in your LOCAL .env. Setting them only in
# Vercel affects the web deploy and ships an APK/IPA with no key.
VITE_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx


# ── Analytics — PostHog ──────────────────────────────────────────────────────
# Project API key is publishable by design. VITE_POSTHOG_HOST is the reverse
# proxy (ph.trunorthapp.com, see vercel.json) so events aren't blocked by
# tracker blockers; VITE_POSTHOG_UI_HOST is where "open in PostHog" links go.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://ph.trunorthapp.com
VITE_POSTHOG_UI_HOST=https://us.posthog.com


# ── Build flags ──────────────────────────────────────────────────────────────
# Opt into the split data bundle. Leave unset for the default single bundle.
# VITE_USE_SPLIT_BUNDLE=1


# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE — used by the Vercel edge functions in api/. These are REAL
# secrets: set them in Vercel → Project → Settings → Environment Variables.
# They are never bundled into the client.
# ─────────────────────────────────────────────────────────────────────────────

# MailerLite — email capture (/api/subscribe) + account deletion
# (/api/delete-account, required for App Store 5.1.1(v) and Google Play's
# data-deletion policy).
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Resend — outbound mail for /api/submit (brand corrections + suggestions)
RESEND_API_KEY=
SUBMIT_INBOX=hello@trunorthapp.com


# ─────────────────────────────────────────────────────────────────────────────
# DATA PIPELINE (~43 vars) — NOT needed to build or run the app.
# The fetchers in scripts/ read these, and in production they are supplied as
# GitHub Actions secrets, not from .env. See the `env:` blocks in
# .github/workflows/*.yml for the authoritative list.
#
# Only set these locally if you are running a specific fetcher by hand, e.g.:
#   FEC_API_KEY=... node scripts/fetch-fec.mjs
#
# Common ones: ANTHROPIC_API_KEY (news extraction), FEC_API_KEY,
# OPENFDA_API_KEY, DOL_API_KEY, COMPANIES_HOUSE_API_KEY, OPENSTATES_API_KEY,
# POSTHOG_API_KEY + POSTHOG_PROJECT_ID (the nightly trending refresh).
# ─────────────────────────────────────────────────────────────────────────────
