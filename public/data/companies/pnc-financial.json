 by number of branches, deposits, and ATMs."},"bbb":{"rating":"A+","accredited":null,"complaintCount":null,"profileUrl":"https://www.bbb.org/us/mi/clio/profile/bank/the-pnc-financial-services-group-inc-0372-90036976/addressId/188479"},"secComplaints":{"count":23,"sample":[{"adsh":"0000713676-25-000036","date":"2025-03-27","filer":"PNC FINANCIAL SERVICES GROUP, INC.  (PNC)  (CIK 0000713676)","form":"8-K"},{"adsh":"0001104659-25-006014","date":"2025-01-24","filer":"SANDY SPRING BANCORP INC  (SASR)  (CIK 0000824410)","form":"8-K"},{"adsh":"0001104659-25-006017","date":"2025-01-24","filer":"Atlantic Union Bankshares Corp  (AUB, AUB-PA)  (CIK 0000883948)","form":"8-K"}]},"logoUrl":"https://commons.wikimedia.org/wiki/Special:FilePath/PNClogo.svg","logoSource":"wikidata_p154","slug":"pnc-financial","news":null,"payRatio":null,"deiBadges":null,"animalCerts":null,"products":null,"storeFootprint":null,"recalls":null,"origin":null,"ownership":null,"charity_irs990":null,"firearms_atf_ffl":null,"environment_ejscreen":null,"ownership_wikidata":null,"privacy_hibp_breaches":null,"litigation_courtlistener":{"caseCount24mo":5,"classActionCount":0,"mostRecentCase":"2026-06-18","cases":[{"caseName":"United States v. Innocent","dateFiled":"2026-06-18","court":"District Court, S.D. Florida","natureOfSuit":"Taxes","isClassAction":false,"sourceUrl":"https://www.courtlistener.com/?q=0%3A26-cv-61734"},{"caseName":"Leisure Investments Holdings LLC - Adversary Proceeding","dateFiled":"2026-05-22","court":"United States Bankruptcy Court, D. Delaware","natureOfSuit":"Injunctive relief - other; 91 Declaratory judgment","isClassAction":false,"sourceUrl":"https://www.courtlistener.com/?q=26-50333"},{"caseName":"Hansen v. Experian Information Solutions Inc","dateFiled":"2026-05-22","court":"District Court, E.D. Wisconsin","natureOfSuit":"Consumer Credit","isClassAction":false,"sourceUrl":"https://www.courtlistener.com/?q=2%3A26-cv-00915"},{"caseName":"Hafezi v. PNC Bank, National Association","dateF