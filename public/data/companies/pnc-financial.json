cial Accounts===\nOn March 2, 2023, Donald Trump Jr., cofounder of news aggregator MxM News, tweeted that PNC had abruptly cancelled all financial services for MxM without explanation. Trump and cofounder Taylor Budowich alleged that PNC disapproved of Trump’s political leanings since no reason was given for the closure. PNC claimed it was a “good faith error” and reopened the account.","logoUrl":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Pittsburgh-Downtown-2019-06-13-Tower-at-PNC-Plaza-01.jpg/330px-Pittsburgh-Downtown-2019-06-13-Tower-at-PNC-Plaza-01.jpg","wikipediaUrl":"https://en.wikipedia.org/wiki/PNC_Financial_Services","extract":"The PNC Financial Services Group, Inc. is an American bank holding company and financial services corporation based in Pittsburgh, Pennsylvania. Its banking subsidiary, PNC Bank, operates in 27 states and the District of Columbia, with 2,629 branches and 9,523 ATMs. PNC Bank is one of the largest banks in the US by assets and by number of branches, deposits, and ATMs."},"bbb":{"rating":"A+","accredited":null,"complaintCount":null,"profileUrl":"https://www.bbb.org/us/mi/clio/profile/bank/the-pnc-financial-services-group-inc-0372-90036976/addressId/188479"},"secComplaints":{"count":23,"sample":[{"adsh":"0000713676-25-000036","date":"2025-03-27","filer":"PNC FINANCIAL SERVICES GROUP, INC.  (PNC)  (CIK 0000713676)","form":"8-K"},{"adsh":"0001104659-25-006014","date":"2025-01-24","filer":"SANDY SPRING BANCORP INC  (SASR)  (CIK 0000824410)","form":"8-K"},{"adsh":"0001104659-25-006017","date":"2025-01-24","filer":"Atlantic Union Bankshares Corp  (AUB, AUB-PA)  (CIK 0000883948)","form":"8-K"}]},"logoUrl":"https://commons.wikimedia.org/wiki/Special:FilePath/PNClogo.svg","logoSource":"wikidata_p154","slug":"pnc-financial","news":null,"payRatio":null,"deiBadges":null,"animalCerts":null,"products":null,"storeFootprint":null,"recalls":null,"origin":null,"ownership":null,"charity_irs990":null,"firearms_atf_ffl":null,"environment_ej